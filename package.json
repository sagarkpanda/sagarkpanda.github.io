{
  "name": "sagarpanda-site",
  "version": "1.0.0",
  "private": true,

  "_comment": "Required now: several homepage/lightbox customizations use Tailwind classes beyond what the theme ships precompiled. `npm run compile` regenerates assets/css/compiled.css (a site-level override, doesn't touch the theme submodule) by scanning both this repo's layouts/assets/js AND the theme's, since Tailwind v4's auto-detection scans the whole project tree from wherever package.json lives.",

  "scripts": {
    "compile": "tailwindcss -i ./themes/hugo-narrow/assets/css/main.css -o ./assets/css/compiled.css --minify",
    "dev": "npm run compile && hugo server -D",
    "build": "npm run compile && hugo --minify",
    "release": "semantic-release"
  },

  "release": {
    "branches": [
      "main"
    ],

    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",

          "releaseRules": [
            { "breaking": true, "release": "major" },
            { "type": "feat", "release": "minor" },
            { "type": "fix", "release": "patch" },
            { "type": "perf", "release": "patch" },
            { "type": "refactor", "release": "patch" },
            { "type": "docs", "release": false },
            { "type": "style", "release": false },
            { "type": "test", "release": false },
            { "type": "ci", "release": false },
            { "type": "build", "release": false },
            { "type": "chore", "release": false }
          ]
        }
      ],

      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits",

          "presetConfig": {
            "types": [
              {
                "type": "feat",
                "section": "✨ Features",
                "hidden": false
              },
              {
                "type": "fix",
                "section": "🐛 Bug Fixes",
                "hidden": false
              },
              {
                "type": "perf",
                "section": "⚡ Performance",
                "hidden": false
              },
              {
                "type": "refactor",
                "section": "♻️ Refactoring",
                "hidden": false
              },
              {
                "type": "docs",
                "section": "📝 Documentation",
                "hidden": false
              },
              {
                "type": "style",
                "section": "🎨 Styling",
                "hidden": false
              },
              {
                "type": "ci",
                "section": "👷 CI",
                "hidden": false
              },
              {
                "type": "build",
                "section": "📦 Build System",
                "hidden": false
              },
              {
                "type": "chore",
                "section": "🧹 Maintenance",
                "hidden": false
              }
            ]
          }
        }
      ],

      "@semantic-release/github"
    ]
  },

  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/cli": "^4.1.17",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "semantic-release": "^25.0.8",
    "tailwindcss": "^4.1.17"
  }
}